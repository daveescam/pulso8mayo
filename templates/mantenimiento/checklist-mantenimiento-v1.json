{
  "id": "tpl-checklist-mantenimiento-v1",
  "nombre": "🔧 Checklist de Mantenimiento General",
  "descripcion": "Inspección general de mantenimiento del local con verificación AI y creación automática de tickets",
  "categoria": "MANTENIMIENTO",
  "version": 1,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "15-20 min",
  "complianceConfig": {
    "complianceType": null,
    "requiredFrequency": "monthly",
    "auditable": false,
    "evidenceRequired": true,
    "criticalForCompliance": false
  },
  "cumplimientoNormativo": [],
  "tags": ["mantenimiento", "inspeccion", "checklist", "preventivo", "AI"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "level": 1,
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "level": 2,
      "role": "Owner",
      "channel": "whatsapp",
      "timeout": "48h"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Checklist de mantenimiento completado"
    },
    {
      "type": "CREATE_MAINTENANCE_TICKET",
      "condition": "issues_found",
      "message": "Crear ticket de mantenimiento para problemas detectados"
    },
    {
      "type": "GENERATE_PDF_REPORT"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "Select",
      "titulo": "Área del Local",
      "obligatorio": true,
      "options": ["Cocina", "Comedor", "Baños", "Almacén", "Estacionamiento", "Área General"]
    },
    {
      "id": "paso-2",
      "type": "PhotoField",
      "titulo": "Equipo HVAC (Aire/Calefacción)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar condición del equipo HVAC: sin daños visibles, filtros limpios, unidad en buen estado general",
        "threshold": 0.7,
        "expectedConditions": [
          "Equipo sin daños visibles",
          "Filtros limpios y en buen estado",
          "Unidad HVAC en condición operativa"
        ]
      }
    },
    {
      "id": "paso-3",
      "type": "YesNo",
      "titulo": "Equipo de Plomería Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-4",
      "type": "YesNo",
      "titulo": "Equipo Eléctrico Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-5",
      "type": "YesNo",
      "titulo": "Mobiliario en Buen Estado",
      "obligatorio": true
    },
    {
      "id": "paso-6",
      "type": "PhotoField",
      "titulo": "Estado General de Pisos y Paredes",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar condición de pisos y paredes: sin grietas visibles, sin daños por agua, pintura en buen estado",
        "threshold": 0.7,
        "expectedConditions": [
          "Pisos sin grietas ni daños",
          "Paredes sin manchas de humedad o daño por agua",
          "Pintura en buen estado"
        ]
      }
    },
    {
      "id": "paso-7",
      "type": "YesNo",
      "titulo": "Equipos de Cocina Operativos",
      "obligatorio": true
    },
    {
      "id": "paso-8",
      "type": "YesNo",
      "titulo": "Equipo de Refrigeración Operativo",
      "obligatorio": true
    },
    {
      "id": "paso-9",
      "type": "TextField",
      "titulo": "Detalle del Problema Encontrado",
      "obligatorio": false
    },
    {
      "id": "paso-10",
      "type": "Select",
      "titulo": "Prioridad",
      "obligatorio": true,
      "options": ["Sin problemas", "Baja", "Normal", "Alta", "Urgente"],
      "logicRules": [
        {
          "id": "lr-prioridad-urgente",
          "condition": "value == 'Urgente'",
          "severity": "CRITICAL",
          "message": "Problema urgente detectado. Se crea ticket de mantenimiento con prioridad ALTA inmediatamente.",
          "actions": ["CREATE_MAINTENANCE_TICKET"],
          "remediationProtocol": "Crear ticket de mantenimiento con prioridad HIGH y notificar al Gerente inmediatamente",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            },
            {
              "role": "Owner",
              "channel": "call_priority",
              "timeout": "2h"
            }
          ]
        },
        {
          "id": "lr-prioridad-alta",
          "condition": "value == 'Alta'",
          "severity": "HIGH",
          "message": "Problema de prioridad alta. Se crea ticket de mantenimiento con prioridad NORMAL.",
          "actions": ["CREATE_MAINTENANCE_TICKET"],
          "remediationProtocol": "Crear ticket de mantenimiento con prioridad NORMAL y notificar al Gerente",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-11",
      "type": "PhotoField",
      "titulo": "Fotos de Evidencia",
      "obligatorio": false,
      "aiVerification": {
        "enabled": true,
        "prompt": "Documentar el problema encontrado en la fotografía: identificar el tipo de daño o deterioro visible",
        "threshold": 0.6,
        "expectedConditions": [
          "Evidencia fotográfica del problema documentado",
          "Imagen clara y enfocada del área afectada"
        ]
      }
    },
    {
      "id": "paso-12",
      "type": "YesNo",
      "titulo": "¿Inspección completada?",
      "obligatorio": true
    }
  ]
}