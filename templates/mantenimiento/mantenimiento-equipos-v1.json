{
  "id": "tpl-mantenimiento-equipos-refrigeradores-v1",
  "nombre": "❄️ Mantenimiento de Equipos de Refrigeración",
  "descripcion": "Mantenimiento preventivo de refrigeradores con verificación AI before/after",
  "categoria": "MANTENIMIENTO",
  "version": 1,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "20-30 min",
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "5.3",
    "requiredFrequency": "monthly",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "5.3",
      "descripcion": "Mantenimiento preventivo de equipos de refrigeración para seguridad alimentaria"
    }
  ],
  "tags": ["mantenimiento", "refrigeracion", "preventivo", "NOM-251", "AI", "before-after"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "level": 1,
      "role": "Técnico",
      "channel": "whatsapp",
      "timeout": "0min",
      "condition": "critical"
    },
    {
      "level": 2,
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "24h",
      "condition": "no_response"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Mantenimiento de equipo de refrigeración completado"
    },
    {
      "type": "UPDATE_MAINTENANCE_SCHEDULE",
      "message": "Actualizar calendario de mantenimiento con fecha de próxima revisión"
    },
    {
      "type": "GENERATE_PDF_REPORT"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "TextField",
      "titulo": "ID del Equipo",
      "obligatorio": true
    },
    {
      "id": "paso-2",
      "type": "PhotoField",
      "titulo": "Limpieza del Condensador (Antes)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar acumulación de polvo y suciedad en los serpentines del condensador: evaluar nivel de acumulación de polvo, presencia de escombros o residuos",
        "threshold": 0.6,
        "expectedConditions": [
          "Serpentines del condensador visibles para evaluación",
          "Nivel de acumulación de polvo identificable",
          "Ausencia o presencia de escombros documentable"
        ]
      }
    },
    {
      "id": "paso-3",
      "type": "PhotoField",
      "titulo": "Limpieza del Condensador (Después)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que los serpentines del condensador estén limpios después del mantenimiento: sin acumulación de polvo, sin escombros, superficies limpias",
        "threshold": 0.75,
        "expectedConditions": [
          "Serpentines del condensador limpios",
          "Sin acumulación de polvo visible",
          "Sin escombros ni residuos"
        ]
      }
    },
    {
      "id": "paso-4",
      "type": "PhotoField",
      "titulo": "Verificación de Sellos de Puerta",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar integridad de los sellos de puerta del refrigerador: sin grietas, sin roturas, alineación correcta del sello con la puerta",
        "threshold": 0.8,
        "expectedConditions": [
          "Sellos de puerta sin grietas ni roturas",
          "Alineación correcta del sello",
          "Cierre hermético de la puerta"
        ]
      },
      "logicRules": [
        {
          "id": "lr-sello-danado",
          "condition": "ai_verification_failed",
          "severity": "HIGH",
          "message": "Sello de puerta dañado detectado. Se requiere reemplazo inmediato para mantener temperatura segura.",
          "actions": ["CREATE_MAINTENANCE_TICKET"],
          "remediationProtocol": "Crear ticket de mantenimiento para reemplazo de sello de puerta",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-5",
      "type": "NumberField",
      "titulo": "Temperatura de Operación (°C)",
      "obligatorio": true,
      "validation": {
        "min": -30,
        "max": 10
      }
    },
    {
      "id": "paso-6",
      "type": "Select",
      "titulo": "Nivel de Refrigerante",
      "obligatorio": true,
      "options": ["Normal", "Bajo", "Muy bajo", "Vacío"],
      "logicRules": [
        {
          "id": "lr-refrigerante-vacio",
          "condition": "value == 'Vacío'",
          "severity": "CRITICAL",
          "message": "Nivel de refrigerante vacío. Riesgo crítico de falla del equipo. Escalación inmediata al técnico.",
          "actions": ["ESCALATE", "CREATE_MAINTENANCE_TICKET"],
          "remediationProtocol": "Recarga de refrigerante urgente por técnico certificado",
          "escalationChain": [
            {
              "role": "Técnico",
              "channel": "whatsapp",
              "timeout": "0min"
            },
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "1h"
            }
          ]
        },
        {
          "id": "lr-refrigerante-muy-bajo",
          "condition": "value == 'Muy bajo'",
          "severity": "HIGH",
          "message": "Nivel de refrigerante muy bajo. Se requiere servicio técnico pronto.",
          "actions": ["CREATE_MAINTENANCE_TICKET"],
          "remediationProtocol": "Programar recarga de refrigerante con técnico certificado",
          "escalationChain": [
            {
              "role": "Técnico",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-7",
      "type": "YesNo",
      "titulo": "¿Ruidos Anormales?",
      "obligatorio": true,
      "branches": [
        {
          "condition": "yes",
          "targetStepId": "paso-escalacion-tecnico"
        }
      ],
      "logicRules": [
        {
          "id": "lr-ruidos-anormales",
          "condition": "value == true",
          "severity": "WARNING",
          "message": "Ruidos anormales detectados en el equipo de refrigeración. Puede indicar desgaste de componentes.",
          "actions": ["ESCALATE"],
          "escalationChain": [
            {
              "role": "Técnico",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-8",
      "type": "PhotoField",
      "titulo": "Limpieza Interior (Después)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que el interior del refrigerador esté limpio después del mantenimiento: sin derrames, superficies limpias, organizado",
        "threshold": 0.75,
        "expectedConditions": [
          "Interior del refrigerador limpio",
          "Sin derrames ni residuos",
          "Productos organizados y ordenados"
        ]
      }
    },
    {
      "id": "paso-9",
      "type": "Date",
      "titulo": "Próxima Revisión Programada",
      "obligatorio": true
    },
    {
      "id": "paso-10",
      "type": "YesNo",
      "titulo": "¿Mantenimiento completado?",
      "obligatorio": true
    }
  ]
}