{
  "id": "tpl-cierre-restaurante-v2",
  "nombre": "🌙 Cierre de Restaurante",
  "descripcion": "Workflow completo de cierre del restaurante con verificación AI, corte de caja y seguridad",
  "categoria": "OPERACIONES_DIARIAS",
  "version": 2,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "15-20 min",
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "5.3",
      "descripcion": "Condiciones sanitarias y control en cierre de operaciones"
    }
  ],
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "5.3",
    "requiredFrequency": "daily",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "tags": ["cierre", "diario", "NOM-251", "corte-de-caja", "seguridad", "AI"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "level": 1,
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "level": 2,
      "role": "Owner",
      "channel": "call_priority",
      "timeout": "30min"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Cierre del restaurante completado exitosamente"
    },
    {
      "type": "UPDATE_BRANCH_STATUS",
      "status": "CLOSED"
    },
    {
      "type": "GENERATE_PDF_REPORT"
    },
    {
      "type": "SYNC_ACCOUNTING",
      "descripcion": "Sincronizar datos de corte de caja con sistema contable"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "GPSLocationField",
      "titulo": "Validación de Ubicación",
      "obligatorio": true,
      "validation": {
        "radiusMeters": 100
      }
    },
    {
      "id": "paso-2",
      "type": "NumberField",
      "titulo": "Corte de Caja - Total Efectivo ($)",
      "obligatorio": true,
      "validation": {
        "min": 0
      }
    },
    {
      "id": "paso-3",
      "type": "NumberField",
      "titulo": "Total Sistema ($)",
      "obligatorio": true,
      "validation": {
        "min": 0
      }
    },
    {
      "id": "paso-4",
      "type": "NumberField",
      "titulo": "Diferencia ($)",
      "obligatorio": false,
      "readOnly": true,
      "logicRules": [
        {
          "id": "rule-diferencia-caja",
          "condition": "abs(value) > 500",
          "severity": "CRITICAL",
          "message": "Diferencia de caja mayor a $500. Se requiere intervención inmediata.",
          "actions": ["BLOCK", "ESCALATE"],
          "escalationChain": [
            {
              "role": "Owner",
              "channel": "call_priority",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-5",
      "type": "PhotoField",
      "titulo": "Limpieza de Cocina",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las superficies estén limpias, sin residuos de alimentos y todo organizado en la cocina",
        "threshold": 0.8,
        "expectedConditions": ["superficies_limpias", "sin_residuos_alimentos", "organizado"]
      },
      "remediationProtocol": {
        "type": "GUIDED_SELF_FIX",
        "instructions": "Limpie las superficies con desinfectante, retire residuos de alimentos y reorganice el área antes de tomar una nueva foto."
      }
    },
    {
      "id": "paso-6",
      "type": "NumberField",
      "titulo": "Temperatura Final Refrigerador (°C)",
      "obligatorio": true,
      "validation": {
        "min": -5,
        "max": 10
      }
    },
    {
      "id": "paso-7",
      "type": "PhotoField",
      "titulo": "Verificación Equipos Apagados",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que los equipos críticos (estufas, hornos, freidoras) estén apagados",
        "threshold": 0.75,
        "expectedConditions": ["equipos_apagados", "sin_indicadores_encendidos"]
      },
      "logicRules": [
        {
          "id": "rule-equipos-encendidos",
          "condition": "ai_verification_detected_equipment_on",
          "severity": "HIGH",
          "message": "Se detectaron equipos encendidos. Todos los equipos deben apagarse antes del cierre.",
          "actions": ["BLOCK"]
        }
      ]
    },
    {
      "id": "paso-8",
      "type": "YesNo",
      "titulo": "Puertas y Ventanas Cerradas",
      "obligatorio": true
    },
    {
      "id": "paso-9",
      "type": "YesNo",
      "titulo": "Sistema de Alarma Activado",
      "obligatorio": true
    },
    {
      "id": "paso-10",
      "type": "PhotoField",
      "titulo": "Inspección Exterior Cierre",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las puertas estén cerradas con llave, sin luces encendidas en el interior y el local seguro",
        "threshold": 0.75,
        "expectedConditions": ["puertas_cerradas_llave", "sin_luces_interior", "local_seguro"]
      }
    },
    {
      "id": "paso-11",
      "type": "NumberField",
      "titulo": "Registro de Mermas ($)",
      "obligatorio": false,
      "validation": {
        "min": 0
      }
    },
    {
      "id": "paso-12",
      "type": "TextField",
      "titulo": "Observaciones del Cierre",
      "obligatorio": false
    },
    {
      "id": "paso-13",
      "type": "instruction",
      "titulo": "Confirmación de Cierre",
      "descripcion": "Revise toda la información capturada. Verifique que el corte de caja sea correcto, los equipos estén apagados y el local seguro antes de confirmar."
    },
    {
      "id": "paso-14",
      "type": "YesNo",
      "titulo": "¿Confirmar cierre completo?",
      "obligatorio": true
    }
  ]
}