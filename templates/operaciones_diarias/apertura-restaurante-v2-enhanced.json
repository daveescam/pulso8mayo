{
  "id": "tpl-apertura-restaurante-v2",
  "nombre": "🌅 Apertura de Restaurante",
  "descripcion": "Workflow completo de apertura del restaurante con verificación AI, control de temperatura y validación GPS",
  "categoria": "OPERACIONES_DIARIAS",
  "version": 2,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "10-15 min",
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "5.2",
      "descripcion": "Control de temperatura y condiciones sanitarias en apertura"
    }
  ],
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "5.2",
    "requiredFrequency": "daily",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "tags": ["apertura", "diario", "NOM-251", "temperatura", "GPS", "AI"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "level": 1,
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "level": 2,
      "role": "Técnico",
      "channel": "whatsapp",
      "timeout": "30min"
    },
    {
      "level": 3,
      "role": "Owner",
      "channel": "call_priority",
      "timeout": "120min"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Apertura del restaurante completada exitosamente"
    },
    {
      "type": "UPDATE_BRANCH_STATUS",
      "status": "OPEN"
    },
    {
      "type": "GENERATE_PDF_REPORT"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "GPSLocationField",
      "titulo": "Validación de Ubicación",
      "obligatorio": true,
      "validation": {
        "radiusMeters": 100
      }
    },
    {
      "id": "paso-2",
      "type": "PhotoField",
      "titulo": "Inspección Exterior",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar limpieza del exterior, letrero en buen estado, puertas en condiciones adecuadas",
        "threshold": 0.75,
        "expectedConditions": ["exterior_limpio", "letrero_visible", "puertas_buen_estado"]
      }
    },
    {
      "id": "paso-3",
      "type": "YesNo",
      "titulo": "Luces y Energía Eléctrica",
      "obligatorio": true,
      "branches": [
        {
          "condition": "no",
          "targetStepId": "paso-reporte-mantenimiento"
        }
      ]
    },
    {
      "id": "paso-4",
      "type": "NumberField",
      "titulo": "Temperatura Ambiente (°C)",
      "obligatorio": true,
      "validation": {
        "min": 15,
        "max": 30
      }
    },
    {
      "id": "paso-5",
      "type": "PhotoField",
      "titulo": "Inspección del Comedor",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las mesas estén limpias, sillas ordenadas y piso limpio en el comedor",
        "threshold": 0.8,
        "expectedConditions": ["mesas_limpias", "sillas_ordenadas", "piso_limpio"]
      }
    },
    {
      "id": "paso-6",
      "type": "PhotoField",
      "titulo": "Inspección de Cocina",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar superficies limpias, equipos en su lugar y sin contaminantes visibles en la cocina",
        "threshold": 0.8,
        "expectedConditions": ["superficies_limpias", "equipos_en_lugar", "sin_contaminantes"]
      }
    },
    {
      "id": "paso-7",
      "type": "PhotoField",
      "titulo": "Verificación de Personal y Uniforme",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que el uniforme esté completo, limpio y con gafete de identificación visible",
        "threshold": 0.75,
        "expectedConditions": ["uniforme_completo", "uniforme_limpio", "gafete_visible"]
      },
      "branches": [
        {
          "condition": "ai_verification_failed",
          "targetStepId": "paso-correccion-uniforme"
        }
      ]
    },
    {
      "id": "paso-8",
      "type": "NumberField",
      "titulo": "Fondo de Caja Inicial ($)",
      "obligatorio": true,
      "validation": {
        "min": 0
      }
    },
    {
      "id": "paso-9",
      "type": "ChecklistField",
      "titulo": "Checklist de Equipos Críticos",
      "obligatorio": true,
      "options": ["Estufas", "Hornos", "Freidoras", "Microondas", "Cafetera", "Lavavajillas"]
    },
    {
      "id": "paso-10",
      "type": "NumberField",
      "titulo": "Temperatura Refrigerador Principal (°C)",
      "obligatorio": true,
      "validation": {
        "min": -5,
        "max": 5
      },
      "logicRules": [
        {
          "id": "rule-temp-refrigerador",
          "condition": "value > 4",
          "severity": "CRITICAL",
          "message": "Temperatura del refrigerador fuera de rango seguro (>4°C). Riesgo de contaminación alimentaria.",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            },
            {
              "role": "Técnico",
              "channel": "whatsapp",
              "timeout": "30min"
            },
            {
              "role": "Owner",
              "channel": "call_priority",
              "timeout": "120min"
            }
          ],
          "actions": ["BLOCK", "ESCALATE"]
        }
      ]
    },
    {
      "id": "paso-11",
      "type": "instruction",
      "titulo": "Confirmación de Apertura",
      "descripcion": "Revise toda la información capturada. Si todo está en orden, confirme la apertura del restaurante."
    },
    {
      "id": "paso-12",
      "type": "YesNo",
      "titulo": "¿Confirmar apertura del restaurante?",
      "obligatorio": true
    }
  ]
}