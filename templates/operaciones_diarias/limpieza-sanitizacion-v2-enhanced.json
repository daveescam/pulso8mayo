{
  "id": "tpl-limpieza-sanitizacion-v2",
  "nombre": "🧹 Limpieza y Sanitización",
  "descripcion": "Workflow de limpieza y sanitización con verificación AI, control de concentración de cloro y validación de superficies críticas",
  "categoria": "OPERACIONES_DIARIAS",
  "version": 2,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "20-30 min",
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "5.2",
      "descripcion": "Limpieza y sanitización de superficies y equipos en contacto con alimentos"
    }
  ],
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "5.2",
    "requiredFrequency": "daily/weekly",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "tags": ["limpieza", "sanitización", "NOM-251", "cloro", "superficies", "AI"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "level": 1,
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "level": 2,
      "role": "Gerente General",
      "channel": "whatsapp",
      "timeout": "60min"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Limpieza y sanitización completada exitosamente"
    },
    {
      "type": "GENERATE_PDF_REPORT"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "Select",
      "titulo": "Tipo de Limpieza",
      "obligatorio": true,
      "options": ["Profunda", "Rutina", "Sanitización"]
    },
    {
      "id": "paso-2",
      "type": "YesNo",
      "titulo": "Productos Químicos Disponibles",
      "obligatorio": true
    },
    {
      "id": "paso-3",
      "type": "NumberField",
      "titulo": "Concentración de Cloro (ppm)",
      "obligatorio": true,
      "validation": {
        "min": 50,
        "max": 200
      }
    },
    {
      "id": "paso-4",
      "type": "PhotoField",
      "titulo": "Mesas de Trabajo",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las superficies de las mesas de trabajo estén limpias y sin residuos",
        "threshold": 0.8,
        "expectedConditions": ["superficie_limpia", "sin_residuos"]
      }
    },
    {
      "id": "paso-5",
      "type": "PhotoField",
      "titulo": "Estufas y Hornos",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que se haya removido la grasa y las superficies de estufas y hornos estén limpias",
        "threshold": 0.75,
        "expectedConditions": ["grasa_removida", "superficie_limpia"]
      },
      "remediationProtocol": {
        "type": "GUIDED_SELF_FIX",
        "instructions": "Aplique desengrasante, deje actuar 5 minutos, frote con estropajo y enjuague. Tome una nueva foto."
      }
    },
    {
      "id": "paso-6",
      "type": "PhotoField",
      "titulo": "Refrigeradores",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que el interior del refrigerador esté limpio, sin derrames y organizado",
        "threshold": 0.75,
        "expectedConditions": ["interior_limpio", "sin_derrames", "organizado"]
      }
    },
    {
      "id": "paso-7",
      "type": "PhotoField",
      "titulo": "Tablas de Cortar",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las tablas de cortar no tengan cortes profundos, estén sanitizadas y con código de colores correcto",
        "threshold": 0.85,
        "expectedConditions": ["sin_cortes_profundos", "sanitizadas", "codigo_colores_correcto"]
      },
      "logicRules": [
        {
          "id": "rule-tablas-cortar",
          "condition": "ai_verification_failed",
          "severity": "CRITICAL",
          "message": "Tablas de cortar no aptas. Riesgo de contaminación cruzada según NOM-251.",
          "actions": ["BLOCK"]
        }
      ]
    },
    {
      "id": "paso-8",
      "type": "PhotoField",
      "titulo": "Cuchillos",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que los cuchillos estén limpios, sin óxido y almacenados correctamente",
        "threshold": 0.8,
        "expectedConditions": ["limpios", "sin_oxido", "almacenados_correctamente"]
      }
    },
    {
      "id": "paso-9",
      "type": "PhotoField",
      "titulo": "Manijas y Pomos",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que manijas y pomos estén sanitizados y sin suciedad visible",
        "threshold": 0.8,
        "expectedConditions": ["sanitizados", "sin_suciedad_visible"]
      },
      "logicRules": [
        {
          "id": "rule-manijas-pomos",
          "condition": "ai_verification_failed",
          "severity": "CRITICAL",
          "message": "Manijas y pomos no sanitizados. Punto crítico de contaminación cruzada.",
          "actions": ["BLOCK"]
        }
      ]
    },
    {
      "id": "paso-10",
      "type": "PhotoField",
      "titulo": "Pisos",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que los pisos estén limpios, sin agua estancada y sin residuos",
        "threshold": 0.7,
        "expectedConditions": ["piso_limpio", "sin_agua_estancada", "sin_residuos"]
      }
    },
    {
      "id": "paso-11",
      "type": "PhotoField",
      "titulo": "Baños",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que los baños estén sanitizados, con suministros abastecidos y piso seco",
        "threshold": 0.75,
        "expectedConditions": ["sanitizados", "suministros_abastecidos", "piso_seco"]
      },
      "logicRules": [
        {
          "id": "rule-banos",
          "condition": "ai_verification_failed",
          "severity": "CRITICAL",
          "message": "Baños no cumplen con estándares de sanitización. Riesgo para salud pública.",
          "actions": ["BLOCK"]
        }
      ]
    },
    {
      "id": "paso-12",
      "type": "PhotoField",
      "titulo": "Comedor",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que mesas, sillas y piso del comedor estén limpios",
        "threshold": 0.75,
        "expectedConditions": ["mesas_limpias", "sillas_limpias", "piso_limpio"]
      }
    },
    {
      "id": "paso-13",
      "type": "YesNo",
      "titulo": "Productos Químicos Guardados Correctamente",
      "obligatorio": true
    },
    {
      "id": "paso-14",
      "type": "NumberField",
      "titulo": "Tiempo Empleado (minutos)",
      "obligatorio": true,
      "validation": {
        "min": 0
      }
    },
    {
      "id": "paso-15",
      "type": "YesNo",
      "titulo": "¿Confirmar limpieza completada?",
      "obligatorio": true
    }
  ]
}