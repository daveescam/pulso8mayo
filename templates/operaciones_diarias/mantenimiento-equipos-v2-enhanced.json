{
  "id": "tpl-mantenimiento-equipos-v2",
  "nombre": "🔧 Mantenimiento de Equipos V2",
  "descripcion": "Workflow de verificación y mantenimiento de equipos de cocina con verificación AI y generación de tickets de mantenimiento",
  "categoria": "OPERACIONES_DIARIAS",
  "version": 2,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "15-20 min",
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "5.4",
      "descripcion": "Mantenimiento indirecto de equipos para cumplimiento sanitario"
    }
  ],
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "5.4",
    "requiredFrequency": "daily/weekly",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": false
  },
  "tags": ["mantenimiento", "equipos", "cocina", "NOM-251", "AI", "tickets"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "level": 1,
      "role": "Técnico",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "level": 2,
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "30min"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Revisión de mantenimiento de equipos completada"
    },
    {
      "type": "CREATE_MAINTENANCE_TICKET",
      "condition": "issues_detected",
      "priority": "URGENT",
      "descripcion": "Se detectaron problemas en equipos que requieren atención de mantenimiento"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "instruction",
      "titulo": "Checklist de Equipos de Cocina",
      "descripcion": "Verifique el estado de cada equipo de cocina. Tome fotos de los equipos principales y reporte cualquier problema detectado."
    },
    {
      "id": "paso-2",
      "type": "PhotoField",
      "titulo": "Estufa/Hornos",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar limpieza, estado operativo y sin daños visibles en estufas y hornos",
        "threshold": 0.75,
        "expectedConditions": ["limpieza_adecuada", "estado_operativo", "sin_danos"]
      }
    },
    {
      "id": "paso-3",
      "type": "PhotoField",
      "titulo": "Freidoras",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar nivel de aceite, limpieza y estado operativo de las freidoras",
        "threshold": 0.75,
        "expectedConditions": ["nivel_aceite_adecuado", "limpieza_adecuada", "estado_operativo"]
      }
    },
    {
      "id": "paso-4",
      "type": "YesNo",
      "titulo": "Microondas Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-5",
      "type": "YesNo",
      "titulo": "Licuadoras/Batidoras Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-6",
      "type": "YesNo",
      "titulo": "Cafetera Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-7",
      "type": "YesNo",
      "titulo": "Hielera Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-8",
      "type": "YesNo",
      "titulo": "Lavavajillas Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-9",
      "type": "NumberField",
      "titulo": "Temperatura de Operación (°C)",
      "obligatorio": true,
      "validation": {
        "min": -20,
        "max": 300
      }
    },
    {
      "id": "paso-10",
      "type": "TextField",
      "titulo": "Problemas Detectados",
      "obligatorio": false
    },
    {
      "id": "paso-11",
      "type": "TextField",
      "titulo": "Acciones Tomadas",
      "obligatorio": false
    },
    {
      "id": "paso-12",
      "type": "YesNo",
      "titulo": "¿Equipos en buen estado?",
      "obligatorio": true,
      "logicRules": [
        {
          "id": "rule-equipos-mal-estado",
          "condition": "value == 'no'",
          "severity": "HIGH",
          "message": "Se detectaron equipos en mal estado. Se creará ticket de mantenimiento urgente.",
          "actions": ["CREATE_MAINTENANCE_TICKET", "BLOCK"],
          "maintenanceTicket": {
            "priority": "URGENT",
            "descripcion": "Equipos de cocina requieren mantenimiento inmediato"
          }
        }
      ]
    }
  ]
}