{
    "id": "tpl-onboarding-empleado-v2",
    "nombre": "👋 Onboarding de Nuevo Empleado",
    "descripcion": "Lista de control y registro para el primer día de trabajo de un nuevo colaborador.",
    "tipo": "ONBOARDING",
    "categoria": "RECURSOS_HUMANOS",
    "version": 2,
    "activo": true,
    "requiereIA": true,
    "duracionEstimada": "45-60 min",
    "cumplimientoNormativo": [
        "NOM-035",
        "LABOR_LAW"
    ],
    "tags": [
        "rh",
        "contratacion",
        "empleado",
        "equipo"
    ],
    "aiConfig": {
        "provider": "moondream",
        "threshold": 0.8
    },
    "complianceConfig": {
        "complianceType": "LABOR_LAW",
        "requiredFrequency": "on_demand",
        "auditable": true,
        "evidenceRequired": true,
        "criticalForCompliance": true
    },
    "pasos": [
        {
            "id": "datos_empleado",
            "type": "text",
            "title": "Nombre Completo del Empleado",
            "required": true
        },
        {
            "id": "puesto",
            "type": "multiple_choice",
            "title": "Puesto Asignado",
            "required": true,
            "options": [
                "Mesero",
                "Cocinero",
                "Lavaloza",
                "Hostess",
                "Cajero",
                "Ayudante General",
                "Gerente"
            ]
        },
        {
            "id": "documentacion",
            "type": "checklist",
            "title": "Entrega de Documentación",
            "description": "Verifique que se reciban/firmen todos los documentos legales.",
            "required": true,
            "options": [
                "Contrato Individual de Trabajo firmado",
                "Copia de Identificación Oficial (INE/Pasaporte)",
                "Comprobante de Domicilio",
                "Alta en IMSS (Hoja Rosa o comprobante)",
                "Carta de Confidencialidad firmada"
            ],
            "validation": {
                "message": "Todos los documentos legales son obligatorios para el ingreso."
            }
        },
        {
            "id": "foto_documentos",
            "type": "photo",
            "title": "Evidencia: Contrato Firmado",
            "description": "Foto de la primera y última hoja del contrato firmado.",
            "required": true
        },
        {
            "id": "entrega_uniforme",
            "type": "checklist",
            "title": "Entrega de Equipo y Uniforme",
            "required": true,
            "options": [
                "Camisa/Polo institucional",
                "Mandil",
                "Gorra/Red para cabello",
                "Zapatos antiderrapantes (verificación visual)"
            ]
        },
        {
            "id": "foto_uniformado",
            "type": "photo",
            "title": "Evidencia: Empleado con Uniforme",
            "description": "Foto del empleado portando el uniforme completo correctamente.",
            "required": true,
            "aiVerification": {
                "enabled": true,
                "prompt": "Verifica que la persona esté usando el uniforme, incluyendo camisa o polo, mandil y gorra o red para el cabello.",
                "threshold": 0.8,
                "expectedConditions": [
                    "wearing_apron",
                    "wearing_uniform_shirt",
                    "wearing_cap_or_hairnet"
                ]
            }
        },
        {
            "id": "capacitacion_inicial",
            "type": "checklist",
            "title": "Capacitación Inicial (Día 1)",
            "required": true,
            "options": [
                "Recorrido por instalaciones (baños, salidas, cocina)",
                "Presentación con el equipo de trabajo",
                "Explicación del Reglamento Interno",
                "Registro de huella/código en sistema de asistencia",
                "Asignación de casillero/espacio personal"
            ]
        },
        {
            "id": "firma_empleado",
            "type": "SignatureField",
            "title": "Firma del Empleado",
            "description": "Confirmo que he recibido mi uniforme, capacitación inicial y he firmado mi contrato.",
            "required": true
        },
        {
            "id": "comentario_gerente",
            "type": "text",
            "title": "Observaciones del Gerente",
            "required": false
        }
    ],
    "completionActions": [
        {
            "type": "UPDATE_USER_STATUS",
            "userId": "{param:userId}",
            "status": "ACTIVE"
        },
        {
            "type": "SEND_NOTIFICATION",
            "target": [
                "RECURSOS_HUMANOS"
            ],
            "channel": "email",
            "message": "👤 Nuevo ingreso completado: {steps.datos_empleado.value}"
        }
    ]
}