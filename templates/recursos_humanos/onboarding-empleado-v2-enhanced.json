{
  "id": "tpl-onboarding-empleado-v2",
  "nombre": "👤 Onboarding de Empleado",
  "descripcion": "Proceso completo de incorporación de nuevo empleado con verificación AI/OCR de documentos y firma de contrato",
  "tipo": "RECURSOS_HUMANOS",
  "version": 2,
  "requiereIA": true,
  "duracionEstimada": "30-45 min",
  "activo": true,
  "tags": ["recursos humanos", "onboarding", "empleado", "contrato", "verificación OCR"],
  "cumplimientoNormativo": [
    {
      "norma": "LABOR_LAW",
      "seccion": "Contratación y Onboarding",
      "descripcion": "Cumplimiento con la Ley Federal del Trabajo para procesos de contratación"
    }
  ],
  "complianceConfig": {
    "complianceType": "LABOR_LAW",
    "regulationSection": "LFT-Titulo-IV",
    "requiredFrequency": "per-event",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": false
  },
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "role": "RH",
      "delayMinutes": 0,
      "channel": "in-app"
    },
    {
      "role": "Gerente",
      "delayMinutes": 1440,
      "channel": "whatsapp"
    }
  ],
  "completionActions": [
    {
      "type": "CREATE_EMPLOYEE_RECORD"
    },
    {
      "type": "SEND_NOTIFICATION",
      "target": "RH",
      "channel": "in-app",
      "message": "Onboarding completado para nuevo empleado"
    },
    {
      "type": "ACTIVATE_SYSTEM_ACCESS"
    },
    {
      "type": "GENERATE_PDF_REPORT"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "TextField",
      "titulo": "Nombre Completo del Empleado",
      "obligatorio": true
    },
    {
      "id": "paso-2",
      "type": "ChecklistField",
      "titulo": "Documentos Requeridos",
      "obligatorio": true,
      "options": [
        "INE/IFE",
        "RFC",
        "NSS (Seguro Social)",
        "Comprobante de Domicilio",
        "Acta de Nacimiento",
        "Contrato Firmado",
        "Carta de Antecedentes No Penales",
        "Certificado Médico"
      ]
    },
    {
      "id": "paso-3",
      "type": "PhotoField",
      "titulo": "Verificación de Documentos (AI/OCR)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar completitud de documentos presentados. Revisar que el nombre del empleado coincida en todos los documentos visibles. Confirmar que los documentos son legibles y válidos.",
        "threshold": 0.7,
        "expectedConditions": [
          "Documento legible",
          "Nombre coincide en documentos",
          "Documento vigente",
          "Fotografía coincide con persona"
        ]
      },
      "branches": [
        {
          "condition": "documento_faltante",
          "targetStepId": "paso-registrar-pendiente"
        }
      ]
    },
    {
      "id": "paso-4",
      "type": "instruction",
      "titulo": "Capacitación Inicial - Revisar políticas de la empresa"
    },
    {
      "id": "paso-5",
      "type": "YesNo",
      "titulo": "¿Tour de Instalaciones Completado?",
      "obligatorio": true
    },
    {
      "id": "paso-6",
      "type": "Select",
      "titulo": "Equipo Asignado",
      "options": [
        "Uniforme",
        "Credencial",
        "Llaves",
        "Tablet/Dispositivo",
        "Herramientas de trabajo"
      ]
    },
    {
      "id": "paso-7",
      "type": "YesNo",
      "titulo": "¿Accesos al Sistema Creados?",
      "obligatorio": true
    },
    {
      "id": "paso-8",
      "type": "YesNo",
      "titulo": "¿Uniforme Entregado?",
      "obligatorio": true
    },
    {
      "id": "paso-9",
      "type": "SignatureField",
      "titulo": "Firma de Contrato",
      "obligatorio": true
    },
    {
      "id": "paso-10",
      "type": "TextField",
      "titulo": "Contacto de Emergencia",
      "obligatorio": true
    },
    {
      "id": "paso-11",
      "type": "TextField",
      "titulo": "Teléfono de Emergencia",
      "obligatorio": true
    },
    {
      "id": "paso-12",
      "type": "YesNo",
      "titulo": "¿Onboarding completado?",
      "obligatorio": true
    }
  ]
}
