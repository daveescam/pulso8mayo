{
  "id": "tpl-fumigacion-v1",
  "nombre": "🐛 Fumigación",
  "descripcion": "Registro de fumigación con verificación OCR de certificados y AI de alimentos expuestos",
  "categoria": "COMPLIANCE",
  "version": 1,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "10-15 min",
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "6.1",
    "requiredFrequency": "monthly/quarterly",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": false
  },
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "6.1",
      "descripcion": "Prácticas de higiene para el proceso de alimentos - control de plagas y fumigación"
    }
  ],
  "tags": ["fumigación", "plagas", "NOM-251", "certificado", "compliance", "OCR", "AI"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "level": 1,
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "level": 2,
      "role": "Owner",
      "channel": "whatsapp",
      "timeout": "24h"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Registro de fumigación completado exitosamente"
    },
    {
      "type": "GENERATE_PDF_REPORT",
      "message": "Generar reporte PDF de registro de fumigación"
    },
    {
      "type": "UPDATE_FUMIGATION_LOG",
      "message": "Actualizar registro de fumigación del establecimiento"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "TextField",
      "titulo": "Empresa Fumigadora",
      "obligatorio": true
    },
    {
      "id": "paso-2",
      "type": "PhotoField",
      "titulo": "Certificado Vigente (OCR)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Realizar OCR del certificado de fumigación para extraer: nombre de la empresa, número de licencia y fecha de vigencia. Verificar que el certificado esté vigente y que los datos coincidan con la empresa indicada.",
        "threshold": 0.7,
        "expectedConditions": [
          "Certificado legible con nombre de empresa visible",
          "Número de licencia profesional visible y legible",
          "Fecha de vigencia vigente (no vencida)"
        ]
      },
      "logicRules": [
        {
          "id": "lr-certificado-vencido",
          "condition": "expiry_date < today || company_mismatch",
          "severity": "CRITICAL",
          "message": "Certificado de fumigación VENCIDO o datos no coinciden. Bloquear operación inmediatamente según NOM-251 Sección 6.1.",
          "actions": ["BLOCK"],
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            },
            {
              "role": "Owner",
              "channel": "call_priority",
              "timeout": "1h"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-3",
      "type": "TextField",
      "titulo": "Áreas Tratadas",
      "obligatorio": true
    },
    {
      "id": "paso-4",
      "type": "TextField",
      "titulo": "Productos Utilizados",
      "obligatorio": true
    },
    {
      "id": "paso-5",
      "type": "TimeField",
      "titulo": "Hora de Aplicación",
      "obligatorio": true
    },
    {
      "id": "paso-6",
      "type": "TextField",
      "titulo": "Precauciones Post-Aplicación",
      "obligatorio": false
    },
    {
      "id": "paso-7",
      "type": "PhotoField",
      "titulo": "Verificación de Alimentos No Expuestos",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que NO hay alimentos expuestos o sin protección en las áreas tratadas. Todos los alimentos deben estar cubiertos, guardados o retirados del área de fumigación conforme a NOM-251.",
        "threshold": 0.85,
        "expectedConditions": [
          "No hay alimentos expuestos en las áreas tratadas",
          "Alimentos debidamente cubiertos o almacenados",
          "Superficies de preparación de alimentos protegidas"
        ]
      },
      "logicRules": [
        {
          "id": "lr-alimentos-expuestos",
          "condition": "ai_verification_failed",
          "severity": "HIGH",
          "message": "Alimentos expuestos detectados en áreas fumigadas. Riesgo de contaminación según NOM-251. Remediación inmediata requerida.",
          "actions": ["BLOCK"],
          "remediationProtocol": "Retirar o cubrir todos los alimentos expuestos en las áreas tratadas. Limpiar superficies de contacto con alimentos. Tomar nueva fotografía para verificación.",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-8",
      "type": "YesNo",
      "titulo": "¿Fumigación completada correctamente?",
      "obligatorio": true
    }
  ]
}
