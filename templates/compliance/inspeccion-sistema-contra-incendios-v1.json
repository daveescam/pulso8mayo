{
  "id": "tpl-inspeccion-sistema-incendios-v1",
  "nombre": "🧯 Inspección Sistema Contra Incendios",
  "descripcion": "Inspección completa del sistema contra incendios con OCR de fechas de extintores y verificación AI de rutas de evacuación",
  "categoria": "COMPLIANCE",
  "version": 1,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "15-20 min",
  "complianceConfig": {
    "complianceType": "NOM-002-STPS",
    "regulationSection": "NOM-002-STPS",
    "requiredFrequency": "monthly/quarterly",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "cumplimientoNormativo": [
    {
      "norma": "NOM-002-STPS",
      "seccion": "General",
      "descripcion": "Condiciones de seguridad - prevención y protección contra incendios en los centros de trabajo"
    }
  ],
  "tags": ["incendios", "extintores", "evacuación", "NOM-002", "seguridad", "compliance", "AI", "OCR"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "level": 1,
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "level": 2,
      "role": "Owner",
      "channel": "whatsapp",
      "timeout": "24h"
    },
    {
      "level": 3,
      "role": "Autoridad",
      "channel": "official",
      "timeout": "persistent"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Inspección de sistema contra incendios completada"
    },
    {
      "type": "GENERATE_PDF_REPORT",
      "message": "Generar reporte PDF de inspección de sistema contra incendios"
    },
    {
      "type": "CREATE_MAINTENANCE_TICKET",
      "condition": "issues_found",
      "message": "Crear ticket de mantenimiento para problemas detectados en sistema contra incendios"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "TextField",
      "titulo": "Ubicación de Extintores",
      "obligatorio": true
    },
    {
      "id": "paso-2",
      "type": "PhotoField",
      "titulo": "Fecha de Vigencia de Extintores (OCR)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Realizar OCR de la etiqueta del extintor para extraer la fecha de vigencia. Verificar que la fecha no esté vencida y que el extintor esté vigente conforme a NOM-002-STPS.",
        "threshold": 0.7,
        "expectedConditions": [
          "Etiqueta del extintor legible con fecha de vigencia visible",
          "Fecha de vigencia vigente (no vencida)",
          "Extintor con sello de inspección intacto"
        ]
      },
      "logicRules": [
        {
          "id": "lr-extintor-vencido",
          "condition": "expiry_date < today",
          "severity": "CRITICAL",
          "message": "Extintor VENCIDO detectado. Reemplazo urgente requerido inmediatamente según NOM-002-STPS.",
          "actions": ["CREATE_MAINTENANCE_TICKET", "BLOCK"],
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-3",
      "type": "PhotoField",
      "titulo": "Señalización de Incendios",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que la señalización de incendios está visible, en buen estado, correctamente colocada y conforme a las normas de seguridad contra incendios.",
        "threshold": 0.8,
        "expectedConditions": [
          "Señales de incendio visibles y legibles",
          "Señalización colocada en posición correcta y altura adecuada",
          "Señales en buen estado sin deterioro"
        ]
      }
    },
    {
      "id": "paso-4",
      "type": "PhotoField",
      "titulo": "Rutas de Evacuación",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las rutas de evacuación están libres de obstrucciones, la señalización de salida es visible, y no hay objetos bloqueando el paso conforme a NOM-002-STPS.",
        "threshold": 0.85,
        "expectedConditions": [
          "Rutas de evacuación despejadas sin obstrucciones",
          "Señalización de salida visible y legible",
          "Piso sin obstáculos que impidan la evacuación"
        ]
      },
      "logicRules": [
        {
          "id": "lr-ruta-bloqueada",
          "condition": "ai_verification_failed",
          "severity": "HIGH",
          "message": "Ruta de evacuación bloqueada u obstruida. Se requiere remediación inmediata.",
          "actions": ["BLOCK"],
          "remediationProtocol": "Despejar inmediatamente la ruta de evacuación y tomar nueva fotografía para verificación",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-5",
      "type": "YesNo",
      "titulo": "Luces de Emergencia Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-6",
      "type": "YesNo",
      "titulo": "Sistema de Rociadores Operativo",
      "obligatorio": true
    },
    {
      "id": "paso-7",
      "type": "YesNo",
      "titulo": "Alarma de Incendio Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-8",
      "type": "Select",
      "titulo": "Simulacro Vigente",
      "obligatorio": true,
      "options": ["Sí - menos de 6 meses", "Sí - 6-12 meses", "No - más de 12 meses", "Nunca"],
      "logicRules": [
        {
          "id": "lr-simulacro-nunca",
          "condition": "value == 'Nunca' || value == 'No - más de 12 meses'",
          "severity": "HIGH",
          "message": "Simulacro de evacuación no vigente. Se debe programar un simulacro inmediatamente según NOM-002-STPS.",
          "actions": ["CREATE_MAINTENANCE_TICKET"],
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-9",
      "type": "TextField",
      "titulo": "Acciones Correctivas",
      "obligatorio": false
    },
    {
      "id": "paso-10",
      "type": "YesNo",
      "titulo": "¿Inspección completada?",
      "obligatorio": true
    }
  ]
}
