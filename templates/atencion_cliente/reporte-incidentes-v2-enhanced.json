{
  "id": "tpl-reporte-incidentes-v2",
  "nombre": "⚠️ Reporte de Incidentes",
  "descripcion": "Reporte de incidentes con verificación AI, evaluación de severidad y escalamiento automático",
  "tipo": "ATENCION_CLIENTE",
  "version": 2,
  "requiereIA": true,
  "duracionEstimada": "5-10 min",
  "activo": true,
  "tags": ["atención cliente", "incidente", "seguridad", "NOM-251", "escalamiento"],
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "Seguridad alimentaria y reporte de incidentes",
      "descripcion": "Cumplimiento con NOM-251-SSA1-2009 para prácticas higiénicas y reporte de incidentes alimentarios"
    }
  ],
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "NOM-251-SSA1-2009",
    "requiredFrequency": "per-event",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "role": "Gerente",
      "delayMinutes": 0,
      "channel": "whatsapp",
      "condition": "CRITICAL"
    },
    {
      "role": "Owner",
      "delayMinutes": 30,
      "channel": "whatsapp"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "OWNER",
      "channel": "whatsapp",
      "message": "Incidente crítico reportado - requiere atención inmediata",
      "condition": "severity=CRITICAL"
    },
    {
      "type": "GENERATE_PDF_REPORT"
    },
    {
      "type": "CREATE_INCIDENT_RECORD"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "Select",
      "titulo": "Tipo de Incidente",
      "obligatorio": true,
      "options": [
        "Queja de cliente",
        "Accidente",
        "Alergia alimentaria",
        "Intoxicación alimentaria",
        "Daño a propiedad",
        "Otro"
      ],
      "logicRules": [
        {
          "id": "rule-intoxicacion",
          "condition": "tipo_incidente == 'Intoxicación alimentaria'",
          "severity": "CRITICAL",
          "message": "Intoxicación alimentaria detectada - Se requiere reporte COFEPRIS y notificación inmediata al propietario",
          "escalationChain": ["OWNER"],
          "actions": [
            {
              "type": "SEND_NOTIFICATION",
              "target": "OWNER",
              "channel": "whatsapp",
              "message": "ALERTA: Intoxicación alimentaria reportada - Se requiere reporte COFEPRIS"
            },
            {
              "type": "CREATE_COFEPRIS_REPORT"
            }
          ]
        },
        {
          "id": "rule-alergia",
          "condition": "tipo_incidente == 'Alergia alimentaria'",
          "severity": "CRITICAL",
          "message": "Alergia alimentaria reportada - Se requiere notificación inmediata y reporte COFEPRIS",
          "escalationChain": ["OWNER"],
          "actions": [
            {
              "type": "SEND_NOTIFICATION",
              "target": "OWNER",
              "channel": "whatsapp",
              "message": "ALERTA: Alergia alimentaria reportada - Se requiere reporte COFEPRIS"
            },
            {
              "type": "CREATE_COFEPRIS_REPORT"
            }
          ]
        },
        {
          "id": "rule-accidente",
          "condition": "tipo_incidente == 'Accidente'",
          "severity": "HIGH",
          "message": "Accidente reportado - Se requiere reporte STPS",
          "escalationChain": ["Gerente"],
          "actions": [
            {
              "type": "CREATE_STPS_REPORT"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-2",
      "type": "Select",
      "titulo": "Severidad",
      "obligatorio": true,
      "options": [
        "Baja",
        "Media",
        "Alta",
        "Crítica"
      ]
    },
    {
      "id": "paso-3",
      "type": "Textarea",
      "titulo": "Descripción del Incidente",
      "obligatorio": true
    },
    {
      "id": "paso-4",
      "type": "PhotoField",
      "titulo": "Fotos de Evidencia",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Analizar el área o condición mostrada en la foto para identificar riesgos de seguridad, condiciones insalubres, peligros físicos o violaciones de normativas de seguridad alimentaria.",
        "threshold": 0.6,
        "expectedConditions": [
          "Área limpia y ordenada",
          "Sin riesgos de seguridad visibles",
          "Equipos en buen estado",
          "Señalización adecuada"
        ]
      }
    },
    {
      "id": "paso-5",
      "type": "TextField",
      "titulo": "Cliente Involucrado",
      "obligatorio": false
    },
    {
      "id": "paso-6",
      "type": "TextField",
      "titulo": "Empleado Involucrado",
      "obligatorio": false
    },
    {
      "id": "paso-7",
      "type": "Textarea",
      "titulo": "Acciones Inmediatas Tomadas",
      "obligatorio": true
    },
    {
      "id": "paso-8",
      "type": "YesNo",
      "titulo": "¿Se requiere seguimiento?",
      "obligatorio": true
    },
    {
      "id": "paso-9",
      "type": "YesNo",
      "titulo": "¿Gerente notificado?",
      "obligatorio": true,
      "logicRules": [
        {
          "id": "rule-gerente-no-notificado",
          "condition": "gerente_notificado == false && severidad IN ['Alta', 'Crítica']",
          "severity": "CRITICAL",
          "message": "BLOCKED: Es obligatorio notificar al gerente para incidentes de severidad Alta o Crítica",
          "actions": [
            {
              "type": "BLOCK"
            }
          ]
        }
      ]
    },
    {
      "id": "paso-10",
      "type": "YesNo",
      "titulo": "¿Reporte completado?",
      "obligatorio": true
    }
  ]
}
