{
  "id": "tpl-recepcion-mercancia-v2",
  "nombre": "📦 Recepción de Mercancía",
  "descripcion": "Workflow de recepción con inspección AI, control de temperatura, verificación OCR y decisión aceptar/rechazar",
  "categoria": "CONTROL_CALIDAD",
  "version": 2,
  "requiereIA": true,
  "duracionEstimada": "10-15 min",
  "activo": true,
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "5.1.2",
    "requiredFrequency": "per-delivery",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "5.1.2",
      "descripcion": "Control de recepción de materias primas"
    }
  ],
  "tags": ["recepcion", "mercancia", "inspeccion", "NOM-251", "control-calidad"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "rol": "Gerente",
      "tiempoMinutos": 0
    },
    {
      "rol": "Purchasing",
      "tiempoMinutos": 30
    },
    {
      "rol": "Owner",
      "tiempoMinutos": 120
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "Gerente",
      "channel": "whatsapp",
      "message": "Recepción de mercancía completada"
    },
    {
      "type": "UPDATE_INVENTORY",
      "message": "Actualizar inventario con mercancía recibida"
    },
    {
      "type": "CREATE_CLAIM",
      "condition": "rejected",
      "message": "Crear reclamo por mercancía rechazada"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "titulo": "Nombre del Proveedor",
      "type": "TextField",
      "obligatorio": true
    },
    {
      "id": "paso-2",
      "titulo": "Inspección del Vehículo",
      "type": "PhotoField",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar limpieza del vehículo de transporte, presencia de unidad de control de temperatura funcionando, y ausencia de riesgos de contaminación visibles",
        "threshold": 0.75,
        "expectedConditions": [
          "Vehículo limpio y sin contaminantes visibles",
          "Unidad de refrigeración funcionando",
          "Sin signos de contaminación cruzada"
        ]
      }
    },
    {
      "id": "paso-3",
      "titulo": "Temperatura del Producto (°C)",
      "type": "NumberField",
      "obligatorio": true,
      "validation": {
        "min": -25,
        "max": 30
      },
      "logicRules": [
        {
          "id": "lr-temp-alta",
          "condition": "value > 4",
          "severity": "CRITICAL",
          "message": "Temperatura del producto fuera de rango seguro. Se requiere rechazo automático.",
          "actions": ["BLOCK", "AUTO_REJECT", "CREATE_MAINTENANCE_TICKET"],
          "escalationChain": [
            {
              "rol": "Gerente",
              "tiempoMinutos": 0
            },
            {
              "rol": "Owner",
              "tiempoMinutos": 30
            }
          ]
        }
      ]
    },
    {
      "id": "paso-4",
      "titulo": "Inspección Visual de Carnes",
      "type": "PhotoField",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar color apropiado de carnes, ausencia de signos de mal olor, e integridad del empaque",
        "threshold": 0.8,
        "expectedConditions": [
          "Color fresco y apropiado del tipo de carne",
          "Sin signos visibles de descomposición u olor anormal",
          "Empaque intacto y sin daños"
        ]
      }
    },
    {
      "id": "paso-5",
      "titulo": "Inspección Visual de Verduras",
      "type": "PhotoField",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar frescura de verduras, ausencia de marchitamiento y ausencia de moho visible",
        "threshold": 0.75,
        "expectedConditions": [
          "Verduras frescas y turgentes",
          "Sin marchitamiento visible",
          "Sin presencia de moho"
        ]
      }
    },
    {
      "id": "paso-6",
      "titulo": "Verificación de Fechas de Caducidad (OCR)",
      "type": "PhotoField",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Realizar OCR de fechas de caducidad en etiquetas y empaques de productos. Verificar que ningún producto esté caducado.",
        "threshold": 0.7,
        "expectedConditions": [
          "Fechas de caducidad legibles vía OCR",
          "Ningún producto con fecha vencida"
        ]
      },
      "logicRules": [
        {
          "id": "lr-producto-caducado",
          "condition": "expiredProductsDetected",
          "severity": "HIGH",
          "message": "Se detectaron productos con fecha de caducidad vencida. Escalación inmediata.",
          "actions": ["ESCALATE"],
          "escalationChain": [
            {
              "rol": "Gerente",
              "tiempoMinutos": 0
            }
          ]
        }
      ]
    },
    {
      "id": "paso-7",
      "titulo": "Cantidad Recibida vs Orden",
      "type": "NumberField",
      "obligatorio": true
    },
    {
      "id": "paso-8",
      "titulo": "Decisión",
      "type": "Select",
      "obligatorio": true,
      "options": ["Aceptar", "Rechazar", "Aceptar con Descuento"],
      "branches": [
        {
          "condition": "Rechazar",
          "targetStepId": "paso-rechazo-total"
        }
      ]
    },
    {
      "id": "paso-9",
      "titulo": "Fotos de Remisión (OCR)",
      "type": "PhotoField",
      "obligatorio": false,
      "aiVerification": {
        "enabled": true,
        "prompt": "Realizar OCR del número de factura/remisión y montos. Verificar coincidencia con datos esperados.",
        "threshold": 0.7,
        "expectedConditions": [
          "Número de factura legible",
          "Montos legibles y verificables"
        ]
      }
    },
    {
      "id": "paso-10",
      "titulo": "Discrepancias Registradas",
      "type": "TextField",
      "obligatorio": false
    },
    {
      "id": "paso-11",
      "titulo": "Confirmación de Recepción",
      "type": "instruction",
      "descripcion": "Revise toda la información capturada y confirme que la recepción está completa y correcta antes de finalizar."
    },
    {
      "id": "paso-12",
      "titulo": "¿Recepción completada?",
      "type": "YesNo",
      "obligatorio": true
    }
  ]
}
