{
  "id": "tpl-control-higiene-personal-v2",
  "nombre": "🧼 Control de Higiene Personal",
  "descripcion": "Verificación diaria de higiene personal del personal Manipulador de alimentos conforme a NOM-251 Sección 4.2",
  "categoria": "CONTROL_CALIDAD",
  "version": 2,
  "requiereIA": true,
  "duracionEstimada": "5-10 min",
  "activo": true,
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "4.2",
    "requiredFrequency": "daily-per-shift",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "4.2",
      "descripcion": "Higiene personal del personal manipulador de alimentos"
    }
  ],
  "tags": ["higiene", "personal", "NOM-251", "control-calidad", "manipuladores"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "rol": "Gerente",
      "tiempoMinutos": 0
    },
    {
      "rol": "RH",
      "tiempoMinutos": 30
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "Gerente",
      "channel": "whatsapp",
      "message": "Control de higiene personal completado"
    },
    {
      "type": "UPDATE_EMPLOYEE_STATUS",
      "message": "Actualizar estado de aptitud del empleado"
    },
    {
      "type": "GENERATE_PDF_REPORT",
      "message": "Generar reporte PDF de control de higiene personal"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "titulo": "Verificación de Manos Limpias",
      "type": "PhotoField",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las manos están lavadas, sin joyas, uñas cortas y limpias",
        "threshold": 0.85,
        "expectedConditions": [
          "Manos visiblemente limpias y lavadas",
          "Sin joyas o accesorios en manos ni muñecas",
          "Uñas cortas, limpias y sin esmalte"
        ]
      },
      "remediationProtocol": {
        "type": "GUIDED_SELF_FIX",
        "maxAttempts": 2,
        "steps": [
          {
            "orden": 1,
            "instruccion": "Diríjase al lavamanos. Lávese las manos con jabón antibacterial durante al menos 20 segundos, frotando entre los dedos y bajo las uñas."
          },
          {
            "orden": 2,
            "instruccion": "Secarse las manos con toallas de papel desechable. Retire cualquier joya o accesorio. Verifique que sus uñas estén cortas."
          },
          {
            "orden": 3,
            "instruccion": "Tome una nueva fotografía de sus manos para re-verificación."
          }
        ]
      }
    },
    {
      "id": "paso-2",
      "titulo": "Verificación de Uniforme Completo",
      "type": "PhotoField",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que el uniforme está completo, limpio, y el cabello está recogido o cubierto",
        "threshold": 0.8,
        "expectedConditions": [
          "Uniforme completo y limpio",
          "Cabello recogido o cubierto con cofia/red",
          "Calzado adecuado y limpio"
        ]
      }
    },
    {
      "id": "paso-3",
      "titulo": "¿Uso de Guantes?",
      "type": "YesNo",
      "obligatorio": true,
      "branches": [
        {
          "condition": "no",
          "targetStepId": "paso-protocolo-guantes"
        }
      ]
    },
    {
      "id": "paso-4",
      "titulo": "Screening de Salud",
      "type": "Select",
      "obligatorio": true,
      "options": ["Sin síntomas", "Fiebre", "Diarrea", "Vómito", "Heridas abiertas", "Dolor de garganta"],
      "logicRules": [
        {
          "id": "lr-sintoma-detectado",
          "condition": "value != 'Sin síntomas'",
          "severity": "CRITICAL",
          "message": "Se detectaron síntomas de enfermedad. El empleado debe ser enviado a casa inmediatamente.",
          "actions": ["BLOCK", "SEND_HOME"],
          "escalationChain": [
            {
              "rol": "Gerente",
              "tiempoMinutos": 0
            }
          ]
        }
      ],
      "branches": [
        {
          "condition": "Heridas abiertas",
          "targetStepId": "paso-proteccion-heridas"
        }
      ]
    },
    {
      "id": "paso-proteccion-heridas",
      "titulo": "Protocolo de Protección de Heridas",
      "type": "instruction",
      "descripcion": "Cubra la herida con vendaje impermeable y guantes. La herida debe estar completamente sellada para poder manipular alimentos. Si la herida no puede ser cubierta adecuadamente, el empleado no debe manipular alimentos."
    },
    {
      "id": "paso-6",
      "titulo": "¿Protección cubierta aplicada?",
      "type": "YesNo",
      "obligatorio": false,
      "condicional": true,
      "condicionMostrar": "paso-4 == 'Heridas abiertas'"
    },
    {
      "id": "paso-protocolo-guantes",
      "titulo": "Protocolo de Corrección de Guantes",
      "type": "instruction",
      "descripcion": "Coloque guantes desechables nuevos. Asegúrese de que cubran completamente las manos y muñecas. Cambie guantes cada vez que cambie de actividad o si se rompen."
    },
    {
      "id": "paso-8",
      "titulo": "¿Guantes puestos correctamente?",
      "type": "YesNo",
      "obligatorio": false,
      "condicional": true,
      "condicionMostrar": "paso-3 == 'no'"
    },
    {
      "id": "paso-9",
      "titulo": "Confirmación de Aptitud",
      "type": "instruction",
      "descripcion": "Verifique que todas las verificaciones de higiene personal han sido completadas satisfactoriamente antes de confirmar la aptitud del empleado."
    },
    {
      "id": "paso-10",
      "titulo": "¿Empleado apto para trabajar?",
      "type": "YesNo",
      "obligatorio": true,
      "logicRules": [
        {
          "id": "lr-no-aptio",
          "condition": "value == 'no'",
          "severity": "CRITICAL",
          "message": "Empleado no apto para trabajar. Notificación inmediata al gerente.",
          "actions": ["BLOCK"],
          "escalationChain": [
            {
              "rol": "Gerente",
              "tiempoMinutos": 0
            }
          ]
        }
      ]
    }
  ]
}
