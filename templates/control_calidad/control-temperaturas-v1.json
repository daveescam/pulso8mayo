{
  "id": "tpl-control-temperaturas-v1",
  "nombre": "🌡️ Control de Temperaturas",
  "descripcion": "Monitoreo de temperaturas de equipos de refrigeración, congelación y alimentos en buffet conforme a NOM-251 Sección 5.3",
  "categoria": "CONTROL_CALIDAD",
  "version": 1,
  "requiereIA": true,
  "duracionEstimada": "10-15 min",
  "activo": true,
  "complianceConfig": {
    "complianceType": "NOM-251",
    "regulationSection": "5.3",
    "requiredFrequency": "cada-4-horas",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "cumplimientoNormativo": [
    {
      "norma": "NOM-251",
      "seccion": "5.3",
      "descripcion": "Control de temperaturas de equipos y alimentos"
    }
  ],
  "tags": ["temperatura", "refrigeracion", "congelacion", "NOM-251", "control-calidad"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "rol": "Gerente",
      "tiempoMinutos": 0
    },
    {
      "rol": "Mantenimiento",
      "tiempoMinutos": 30
    },
    {
      "rol": "Owner",
      "tiempoMinutos": 120
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "Gerente",
      "channel": "whatsapp",
      "message": "Control de temperaturas completado"
    },
    {
      "type": "GENERATE_PDF_REPORT",
      "message": "Generar reporte PDF de control de temperaturas"
    },
    {
      "type": "UPDATE_TEMPERATURE_LOG",
      "message": "Actualizar registro de temperaturas"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "titulo": "Refrigerador 1 (°C)",
      "type": "TemperatureField",
      "obligatorio": true,
      "validation": {
        "min": -5,
        "max": 10
      },
      "logicRules": [
        {
          "id": "lr-ref1-temp-alta",
          "condition": "value > 4",
          "severity": "CRITICAL",
          "message": "Temperatura del Refrigerador 1 arriba de 4°C. Rango de peligro detectado.",
          "actions": ["ESCALATE"],
          "escalationChain": [
            {
              "rol": "Gerente",
              "tiempoMinutos": 0
            },
            {
              "rol": "Mantenimiento",
              "tiempoMinutos": 30
            }
          ]
        }
      ],
      "remediationProtocol": {
        "type": "SELF_REMEDIATE",
        "steps": [
          {
            "orden": 1,
            "instruccion": "Verifique que la puerta del refrigerador esté completamente cerrada."
          },
          {
            "orden": 2,
            "instruccion": "Espere 15 minutos y vuelva a tomar la temperatura."
          },
          {
            "orden": 3,
            "instruccion": "Si la temperatura persiste arriba de 4°C, notifique al Gerente y al área de Mantenimiento inmediatamente."
          }
        ]
      }
    },
    {
      "id": "paso-2",
      "titulo": "Refrigerador 2 (°C)",
      "type": "TemperatureField",
      "obligatorio": true,
      "validation": {
        "min": -5,
        "max": 10
      },
      "logicRules": [
        {
          "id": "lr-ref2-temp-alta",
          "condition": "value > 4",
          "severity": "CRITICAL",
          "message": "Temperatura del Refrigerador 2 arriba de 4°C. Rango de peligro detectado.",
          "actions": ["ESCALATE"],
          "escalationChain": [
            {
              "rol": "Gerente",
              "tiempoMinutos": 0
            },
            {
              "rol": "Mantenimiento",
              "tiempoMinutos": 30
            }
          ]
        }
      ]
    },
    {
      "id": "paso-3",
      "titulo": "Congelador 1 (°C)",
      "type": "TemperatureField",
      "obligatorio": true,
      "validation": {
        "min": -30,
        "max": -10
      },
      "logicRules": [
        {
          "id": "lr-cong1-temp-alta",
          "condition": "value > -18",
          "severity": "HIGH",
          "message": "Temperatura del Congelador 1 arriba de -18°C. Verificar funcionamiento del equipo.",
          "actions": ["ESCALATE"]
        }
      ],
      "remediationProtocol": {
        "type": "SELF_REMEDIATE",
        "steps": [
          {
            "orden": 1,
            "instruccion": "Verifique que la puerta del congelador esté completamente cerrada y sin obstrucciones."
          },
          {
            "orden": 2,
            "instruccion": "Revise si hay acumulación de hielo que pueda estar afectando el sellado."
          },
          {
            "orden": 3,
            "instruccion": "Espere 15 minutos y vuelva a tomar la temperatura. Si persiste, notifique a Mantenimiento."
          }
        ]
      }
    },
    {
      "id": "paso-4",
      "titulo": "Congelador 2 (°C)",
      "type": "TemperatureField",
      "obligatorio": true,
      "validation": {
        "min": -30,
        "max": -10
      },
      "logicRules": [
        {
          "id": "lr-cong2-temp-alta",
          "condition": "value > -18",
          "severity": "HIGH",
          "message": "Temperatura del Congelador 2 arriba de -18°C. Verificar funcionamiento del equipo.",
          "actions": ["ESCALATE"]
        }
      ]
    },
    {
      "id": "paso-5",
      "titulo": "Alimentos Cocidos en Buffet",
      "type": "PhotoField",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar temperatura de alimentos cocidos en buffet mediante OCR de termómetro visible. Verificar que los alimentos están cubiertos y protegidos.",
        "threshold": 0.7,
        "expectedConditions": [
          "Temperatura de alimentos cocidos visible en termómetro ≥ 60°C",
          "Alimentos cubiertos o protegidos adecuadamente"
        ]
      },
      "logicRules": [
        {
          "id": "lr-buffet-temp-baja",
          "condition": "foodTemperature < 60",
          "severity": "WARNING",
          "message": "Alimentos cocidos en buffet por debajo de 60°C. Zona de peligro potencial.",
          "actions": ["ESCALATE"]
        }
      ]
    },
    {
      "id": "paso-6",
      "titulo": "¿Alimentos en zona de peligro?",
      "type": "YesNo",
      "obligatorio": true,
      "logicRules": [
        {
          "id": "lr-zona-peligro",
          "condition": "value == true",
          "severity": "CRITICAL",
          "message": "Alimentos detectados en zona de peligro de temperatura (4°C - 60°C). Acción inmediata requerida.",
          "actions": ["BLOCK", "ESCALATE"],
          "escalationChain": [
            {
              "rol": "Gerente",
              "tiempoMinutos": 0
            }
          ]
        }
      ]
    },
    {
      "id": "paso-7",
      "titulo": "Acciones Correctivas Tomadas",
      "type": "TextField",
      "obligatorio": false
    },
    {
      "id": "paso-8",
      "titulo": "Protocolo de Remedición de Temperatura",
      "type": "instruction",
      "descripcion": "Si se detectaron temperaturas fuera de rango: 1) Verificar puertas cerradas, 2) Revisar sellos de equipos, 3) Reubicar alimentos si es necesario, 4) Notificar a Mantenimiento si el problema persiste, 5) Documentar todas las acciones correctivas tomadas."
    },
    {
      "id": "paso-9",
      "titulo": "¿Temperaturas verificadas?",
      "type": "YesNo",
      "obligatorio": true
    },
    {
      "id": "paso-10",
      "titulo": "Observaciones",
      "type": "TextField",
      "obligatorio": false
    }
  ]
}
