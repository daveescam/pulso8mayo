{
  "id": "tpl-control-accesos-v1",
  "nombre": "🚪 Control de Accesos",
  "descripcion": "Registro y control de acceso de visitantes, proveedores y empleados con verificación OCR de identificación",
  "categoria": "SEGURIDAD",
  "version": 1,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "3-5 min",
  "cumplimientoNormativo": [],
  "complianceConfig": {
    "complianceType": null,
    "requiredFrequency": "per-event",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": false
  },
  "tags": ["accesos", "visitantes", "proveedores", "seguridad", "OCR", "registro"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "role": "Owner",
      "channel": "call_priority",
      "timeout": "0min"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "Gerente",
      "channel": "whatsapp",
      "condition": "unauthorized_visit",
      "message": "Se registró un acceso no autorizado o sin verificación completa"
    },
    {
      "type": "REGISTER_ACCESS_DB",
      "message": "Registrar acceso en base de datos de control de visitantes"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "Select",
      "titulo": "Tipo de Visita",
      "obligatorio": true,
      "options": ["Empleado", "Proveedor", "Visitante", "Contratista"],
      "branches": [
        {
          "condition": "Proveedor",
          "targetStepId": "paso-verificacion-autorizacion"
        },
        {
          "condition": "Visitante",
          "targetStepId": "paso-acompanante"
        }
      ]
    },
    {
      "id": "paso-2",
      "type": "PhotoField",
      "titulo": "Documento de Identificación (OCR)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Realizar OCR del documento de identificación para extraer: nombre completo, número de identificación y fecha de vigencia. Verificar que el documento no esté vencido.",
        "threshold": 0.7,
        "expectedConditions": [
          "Nombre completo legible vía OCR",
          "Número de identificación legible",
          "Fecha de vigencia legible y vigente"
        ]
      }
    },
    {
      "id": "paso-3",
      "type": "TextField",
      "titulo": "Nombre Completo",
      "obligatorio": true
    },
    {
      "id": "paso-4",
      "type": "TextField",
      "titulo": "Empresa / Procedencia",
      "obligatorio": false
    },
    {
      "id": "paso-5",
      "type": "TextField",
      "titulo": "Motivo de la Visita",
      "obligatorio": true
    },
    {
      "id": "paso-6",
      "type": "TextField",
      "titulo": "Persona que Autoriza",
      "obligatorio": true
    },
    {
      "id": "paso-7",
      "type": "TimeField",
      "titulo": "Hora de Entrada",
      "obligatorio": true
    },
    {
      "id": "paso-8",
      "type": "TimeField",
      "titulo": "Hora de Salida",
      "obligatorio": false
    }
  ]
}
