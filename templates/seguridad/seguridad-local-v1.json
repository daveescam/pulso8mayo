{
  "id": "tpl-seguridad-local-v1",
  "nombre": "🔒 Seguridad del Local",
  "descripcion": "Inspección de seguridad del establecimiento con verificación AI de cámaras, extintores y rutas de evacuación",
  "categoria": "SEGURIDAD",
  "version": 1,
  "activo": true,
  "requiereIA": true,
  "duracionEstimada": "10-15 min",
  "cumplimientoNormativo": [
    {
      "norma": "NOM-002-STPS",
      "seccion": "5",
      "descripcion": "Condiciones de seguridad en los centros de trabajo"
    }
  ],
  "complianceConfig": {
    "complianceType": "NOM-002-STPS",
    "regulationSection": "5",
    "requiredFrequency": "monthly",
    "auditable": true,
    "evidenceRequired": true,
    "criticalForCompliance": true
  },
  "tags": ["seguridad", "inspeccion", "NOM-002-STPS", "cctv", "extintores", "evacuacion", "mensual"],
  "aiConfig": {
    "provider": "moondream",
    "fallbackProvider": "openai",
    "maxRetries": 2
  },
  "escalationChain": [
    {
      "role": "Gerente",
      "channel": "whatsapp",
      "timeout": "0min"
    },
    {
      "role": "Owner",
      "channel": "call_priority",
      "timeout": "0min",
      "condition": "critical_security_failure"
    }
  ],
  "completionActions": [
    {
      "type": "SEND_NOTIFICATION",
      "target": "GERENTE",
      "channel": "whatsapp",
      "message": "Inspección de seguridad del local completada"
    },
    {
      "type": "GENERATE_PDF_REPORT"
    },
    {
      "type": "CREATE_MAINTENANCE_TICKET",
      "condition": "issues_detected",
      "priority": "urgent",
      "message": "Se detectaron problemas de seguridad que requieren atención de mantenimiento"
    }
  ],
  "pasos": [
    {
      "id": "paso-1",
      "type": "PhotoField",
      "titulo": "Verificación de Puertas",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las puertas estén aseguradas, cerraduras funcionando correctamente y sin daños visibles en marcos o chapas",
        "threshold": 0.75,
        "expectedConditions": [
          "Puertas aseguradas correctamente",
          "Cerraduras funcionando sin daño",
          "Sin daños visibles en marcos o chapas"
        ]
      }
    },
    {
      "id": "paso-2",
      "type": "YesNo",
      "titulo": "Ventanas Seguras",
      "obligatorio": true
    },
    {
      "id": "paso-3",
      "type": "YesNo",
      "titulo": "Sistema de Alarma Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-4",
      "type": "PhotoField",
      "titulo": "Cámaras CCTV",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar posición correcta de la cámara, lente limpio sin obstrucciones, y luz indicadora encendida que confirma funcionamiento",
        "threshold": 0.7,
        "expectedConditions": [
          "Cámara en posición correcta",
          "Lente limpio y sin obstrucciones",
          "Luz indicadora encendida"
        ]
      },
      "logicRules": [
        {
          "id": "lr-cctv-fuera-servicio",
          "condition": "cameraNotWorking",
          "severity": "HIGH",
          "message": "Cámara CCTV no funcionando. Se requiere atención inmediata de mantenimiento.",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ],
          "actions": ["NOTIFY", "CREATE_MAINTENANCE_TICKET"]
        }
      ]
    },
    {
      "id": "paso-5",
      "type": "YesNo",
      "titulo": "Iluminación Exterior Funcionando",
      "obligatorio": true
    },
    {
      "id": "paso-6",
      "type": "PhotoField",
      "titulo": "Señalización de Emergencia",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Verificar que las señales de salida estén iluminadas y visibles, y que la señalización de emergencia esté en buen estado y correctamente colocada",
        "threshold": 0.8,
        "expectedConditions": [
          "Señales de salida iluminadas",
          "Señalización de emergencia visible",
          "Señales en buen estado y correctamente colocadas"
        ]
      }
    },
    {
      "id": "paso-7",
      "type": "PhotoField",
      "titulo": "Extintores - Fecha de Vigencia (OCR)",
      "obligatorio": true,
      "aiVerification": {
        "enabled": true,
        "prompt": "Realizar OCR de la fecha de vigencia en la etiqueta del extintor. Verificar que el extintor no esté vencido y que el sello de seguridad esté intacto.",
        "threshold": 0.7,
        "expectedConditions": [
          "Fecha de vigencia legible vía OCR",
          "Extintor dentro de vigencia",
          "Sello de seguridad intacto"
        ]
      },
      "logicRules": [
        {
          "id": "lr-extintor-vencido",
          "condition": "extinguisherExpired",
          "severity": "CRITICAL",
          "message": "Extintor vencido detectado. Reemplazo urgente requerido según NOM-002-STPS.",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            },
            {
              "role": "Owner",
              "channel": "call_priority",
              "timeout": "0min"
            }
          ],
          "actions": ["BLOCK", "ESCALATE", "CREATE_MAINTENANCE_TICKET"]
        }
      ]
    },
    {
      "id": "paso-8",
      "type": "YesNo",
      "titulo": "Botiquín de Primeros Auxilios Completo",
      "obligatorio": true
    },
    {
      "id": "paso-9",
      "type": "YesNo",
      "titulo": "Rutas de Evacuación Despejadas",
      "obligatorio": true,
      "logicRules": [
        {
          "id": "lr-rutas-bloqueadas",
          "condition": "value == 'no'",
          "severity": "HIGH",
          "message": "Rutas de evacuación bloqueadas. Se requiere remedio inmediato para garantizar la seguridad del personal y clientes.",
          "escalationChain": [
            {
              "role": "Gerente",
              "channel": "whatsapp",
              "timeout": "0min"
            }
          ],
          "actions": ["BLOCK", "ESCALATE", "REQUIRE_REMEDIATION"]
        }
      ]
    },
    {
      "id": "paso-10",
      "type": "YesNo",
      "titulo": "¿Inspección de seguridad completada?",
      "obligatorio": true
    }
  ]
}
